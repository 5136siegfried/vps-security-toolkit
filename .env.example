# ================================================================
#  .env.example — vps-security-toolkit
#  Copier en .env (local) ou configs/<hostname>.env (par hôte)
#  Ne jamais committer le fichier rempli.
# ================================================================

# ── Nginx ────────────────────────────────────────────────────
# Chemins des access logs séparés par des virgules.
# Si vide : fallback automatique sur /var/log/nginx/*access*.log
NGINX_LOG_PATHS=

# Nombre de lignes analysées par fichier de log (défaut 5000)
NGINX_LOG_LINES=5000

# ── Docker ───────────────────────────────────────────────────
# Nombre de lignes de logs lues par conteneur (défaut 500)
DOCKER_LOG_LINES=500

# ── Notifications ────────────────────────────────────────────
# Score sous lequel la notification se déclenche (défaut 70)
NOTIFY_SCORE_THRESHOLD=70

# Webhook Discord ou Slack — laisser vide pour désactiver
NOTIFY_WEBHOOK_URL=
# discord ou slack
NOTIFY_WEBHOOK_TYPE=discord

# Mail — laisser vide pour désactiver
# Nécessite mail ou sendmail disponible sur l'hôte
NOTIFY_MAIL_TO=
NOTIFY_MAIL_FROM=